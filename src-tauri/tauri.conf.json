{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QTKT Maker",
  "version": "1.0.4",
  "identifier": "com.qtkt.maker",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "QTKT Maker",
        "width": 1200,
        "height": 800,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Nguyen Duy Truong",
    "shortDescription": "QTKT Maker",
    "longDescription": "Phần mềm tạo QTKT chuẩn Y tế Việt Nam.",
    "linux": {
      "deb": {
        "depends": ["fonts-dejavu", "fonts-liberation", "fonts-noto"]
      }
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": true
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
